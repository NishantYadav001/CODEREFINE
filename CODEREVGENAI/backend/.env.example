# ════════════════════════════════════════════════════════════════
# CODEREFINE - Environment Configuration Template
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# SECURITY WARNING: Never commit .env file to version control!
# ════════════════════════════════════════════════════════════════

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APPLICATION SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PROJECT_NAME=Code Refine
VERSION=2.0.0
ENVIRONMENT=development  # development | staging | production
DEBUG=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API KEYS & SERVICES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Get from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_gemini_key_here

# Optional: OpenAI/Claude API keys
# OPENAI_API_KEY=sk_your_key_here
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECURITY
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-on-32-characters-minimum

# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
APP_ENCRYPTION_KEY=your-16-char-hex-key

# Admin credentials
ADMIN_PASSWORD=password  # Change in production!

# CORS - Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://localhost:3000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MySQL/MariaDB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=coderefine

# Optional: PostgreSQL
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password

# Optional: SQLite (for development)
# DB_TYPE=sqlite
# DB_PATH=./coderefine.db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EMAIL CONFIGURATION (Optional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_SENDER_EMAIL=noreply@coderefine.ai

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL SERVICES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Sentry Error Tracking
# SENTRY_DSN=https://your-key@sentry.io/your-project

# Redis Cache
# REDIS_URL=redis://localhost:6379

# Celery Task Queue
# CELERY_BROKER_URL=redis://localhost:6379/0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LOGGING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json  # json | text
LOG_FILE=./logs/coderefine.log

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FEATURES & LIMITS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Rate limiting (requests per minute)
RATE_LIMIT=100

# Code review timeout (seconds)
REVIEW_TIMEOUT=30

# Max file size for upload (bytes)
MAX_FILE_SIZE=5242880  # 5MB

# Enable plagiarism detection
PLAGIARISM_CHECK_ENABLED=true

# Enable email notifications
EMAIL_NOTIFICATIONS=false

# ════════════════════════════════════════════════════════════════
# SETUP COMPLETED
# Now you can run: python main.py or docker-compose up
# ════════════════════════════════════════════════════════════════

# Security
APP_ENCRYPTION_KEY=generate_using_fernet_key

# SMTP Email Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_SENDER_EMAIL=noreply@coderefine.ai